# Secrets — NEVER commit. Per code_standard.md sec.7.
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example
*.key
*.pem
*.p12
*.pfx
*.crt

# Build outputs
node_modules/
**/node_modules/
dist/
build/
out/
cache/
target/
*.tsbuildinfo
lcov.info

# Foundry
forge-cache/
broadcast/

# Noir / bb generated artifacts (live under <circuit>/target/, covered by target/)
# but list explicitly in case a circuit emits next to its source:
*.gz
**/vk
**/vk_hash
**/kurier_vk_hash
**/proof
**/public_inputs

# Dapp prebuild copies circuit JSON artifacts into public/circuits;
# they are regenerated from code/circuits/<name>/target/<name>.json
# by scripts/copy-circuit-artifacts.mjs on every dev/build.
code/dapp/public/circuits/
**/public_inputs.bad

# External code mirrored locally for reference — each has its own upstream repo
horizen-docs/
zkVerify-docs/
referenced_repos/

# Python
**/__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

