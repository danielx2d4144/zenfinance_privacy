# Day-11 data-api config. Copy to .env (gitignored) and fill in real values.

# Server
PORT=8787
HOST=0.0.0.0
LOG_LEVEL=info

# Postgres (the docker-compose stack from code/infra/data-stack exposes 5432)
DATABASE_URL=postgres://graph:graph@localhost:5432/graphnode

# X-API-Key value clients must send to use action endpoints.
# Any non-empty string >= 16 chars; tests inject their own.
API_KEY=dev-api-key-please-rotate-before-prod

# Anvil fixture (re-uses the Day-10 docker stack)
ANVIL_HTTPS=http://localhost:8545
ANVIL_CHAIN_ID=31337
# First Anvil account.
RELAYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# Set after running code/contracts/script/EmitTestEvents.s.sol.
PRIVACY_ENTRY_ADDRESS=0x5FC8d32690cc91D4c39d9d3abcBD16989F875707
MOCK_USDC_ADDRESS=0xCf7Ed3AccA5a467e9e704C703E8D87F634fB0Fc9
