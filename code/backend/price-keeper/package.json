{
  "name": "@lending/price-keeper",
  "version": "0.1.0",
  "private": true,
  "description": "Day-9 keeper: fetches signed Stork BTCUSD updates and pushes them to the on-chain Stork verifier so Oracle.getPrice(cbBTC) stays fresh.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <23"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "push-once": "tsx scripts/push-once.ts",
    "start": "tsx scripts/start.ts",
    "accrue": "tsx scripts/accrue.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "pino": "^9.5.0",
    "undici": "^6.21.0",
    "viem": "^2.52.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
