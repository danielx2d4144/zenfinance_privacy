# Day-9 price-keeper config. Copy to .env (gitignored) and fill in real values.

# Base Sepolia RPC + signer
BASE_SEPOLIA_HTTPS=https://sepolia.base.org
RELAYER_PRIVATE_KEY=<paste-fresh-private-key-here>

# Contracts on Base Sepolia
ORACLE_BASE_SEPOLIA=<oracle-address-from-DeployOracle>
STORK_BASE_SEPOLIA=0x647DFd812BC1e116c6992CB2bC353b2112176fD6

# Stork REST API. Get a token by emailing sales@stork.network — required to
# fetch signed price updates. The "jp" host is the production REST; the "dev"
# host is for development/testnet keys.
STORK_REST_URL=https://rest.jp.stork-oracle.network
STORK_API_TOKEN=<paste-stork-basic-auth-token>

# Feeds to push every cadence. Comma-separated asset symbols.
STORK_FEEDS=BTCUSD

# Cadence + behavior knobs.
PUSH_INTERVAL_SECONDS=30
PRICE_MOVE_THRESHOLD_BPS=50  # 0.5%

# accrue-keeper target. Set after DeployLendingStack runs.
RATE_MODEL_BASE_SEPOLIA=<rate-model-address>
ACCRUE_ASSETS=0,1
ACCRUE_INTERVAL_SECONDS=300  # 5 min
