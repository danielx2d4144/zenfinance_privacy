# Day-8 attestation pipeline credentials.
# Copy to `.env` and fill in real values. `.env` is gitignored.

# Kurier REST API (zkVerify proof relayer hosted by Horizen Labs).
# Sign up at horizenlabs.io and obtain a project API key.
KURIER_API_KEY=<paste-key-here>
KURIER_BASE_URL=https://relayer-api-testnet.horizenlabs.io/api/v1

# Destination chain id that aggregations get published to. Without this,
# proofs verify on Volta but never enter the aggregation queue (status
# stops at Finalized). Day-8 default: Base Sepolia (84532). Once Horizen
# L3 has its own zkVerify proxy deployed, switch to 2651420.
KURIER_TARGET_CHAIN_ID=84532

# zkVerify Volta testnet (the chain the aggregation proof lives on).
# WSS is what's currently published; the substrate WS client expects this scheme.
ZKVERIFY_VOLTA_WSS=wss://zkverify-volta-rpc.zkverify.io
ZKVERIFY_EXPLORER=https://zkverify-testnet.subscan.io

# Horizen testnet (Caldera L3 on Base Sepolia; chain id 2651420).
HORIZEN_TESTNET_HTTPS=https://horizen-testnet.rpc.caldera.xyz/http
HORIZEN_TESTNET_WSS=wss://horizen-testnet.rpc.caldera.xyz/ws
HORIZEN_TESTNET_CHAIN_ID=2651420
HORIZEN_EXPLORER=https://horizen-testnet.explorer.caldera.xyz

# Relayer EOA — funded with a small amount of bridged Base Sepolia ETH
# (bridge from base-sepolia via https://horizen-testnet.hub.caldera.xyz/).
# Generate fresh; never reuse a wallet you care about.
RELAYER_PRIVATE_KEY=<paste-fresh-private-key-here>
RELAYER_ADDRESS=<paste-corresponding-address-here>
