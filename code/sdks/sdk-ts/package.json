{
  "name": "@lending/sdk-ts",
  "version": "0.1.0",
  "private": true,
  "description": "Day-12 TypeScript SDK for the zenfinance privacy lending protocol REST API.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <23"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./generated/types": {
      "types": "./dist/generated/types.d.ts",
      "default": "./dist/generated/types.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "codegen": "openapi-typescript ../../../docs/openapi.json -o src/generated/types.ts",
    "example:deposit": "tsx examples/deposit.ts",
    "test": "vitest run"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.0",
    "openapi-typescript": "^7.4.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
