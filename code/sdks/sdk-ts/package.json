{
  "name": "@lending/sdk-ts",
  "version": "0.1.0",
  "private": true,
  "description": "Day-12 TypeScript SDK for the zenfinance privacy lending protocol REST API.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <23"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "codegen": "openapi-typescript ../../../docs/openapi.json -o src/generated/types.ts",
    "example:deposit": "tsx examples/deposit.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "undici": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "openapi-typescript": "^7.4.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
